    <!-- 6. BOOTSTRAP COMPONENT: Modal HTML Content -->
    <div class="modal fade" id="projectModal" tabindex="-1" aria-labelledby="projectModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-3">
                <div class="modal-header border-bottom border-slate-100">
                    <h2 class="modal-title fs-5 font-bold text-slate-800" id="projectModalLabel">Buat Proyek Baru</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="mb-3">
                            <label for="projectName" class="form-label text-sm font-semibold text-slate-700">Nama Proyek</label>
                            <input type="text" class="form-control" id="projectName" placeholder="Masukkan nama proyek">
                        </div>
                        <div class="mb-3">
                            <label for="projectCategory" class="form-label text-sm font-semibold text-slate-700">Kategori</label>
                            <select class="form-select" id="projectCategory">
                                <option selected>Pilih kategori...</option>
                                <option value="1">UI/UX Design</option>
                                <option value="2">Backend</option>
                                <option value="3">Frontend</option>

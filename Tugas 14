                        <!-- 9. BOOTSTRAP COMPONENT: Pagination (Di dalam pembungkus tabel putih) -->
                        <div class="px-6 py-3 bg-white border-t border-slate-100 d-flex justify-content-end">
                            <nav aria-label="Navigasi halaman data proyek">
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item disabled">
                                        <a class="page-link" href="#" aria-label="Halaman Sebelumnya">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
